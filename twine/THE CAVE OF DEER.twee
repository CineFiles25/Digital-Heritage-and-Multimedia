@keyframes glowPulse {
  from {
    text-shadow:
      0 0 4px rgba(255,200,100,0.5),
      0 0 8px rgba(255,150,60,0.4);
  }
  to {
    text-shadow:
      0 0 10px rgba(255,220,150,0.9),
      0 0 20px rgba(255,140,50,0.7);
  }
}
/* ===== Scene color variations ===== */
.common-scene {
  border-left: 3px solid rgba(87, 63, 125, 0.7);
  padding-left: 0.8rem;
}

.character-scene {
  border-left: 3px solid rgba(210, 106, 53, 0.75);
  padding-left: 0.8rem;
}

.final-scene {
  border-left: 3px solid rgba(74, 126, 91, 0.7);
  padding-left: 0.8rem;
}


/* ===== Simple ambient animation ===== */
@keyframes pulseVision {
  0% {
    text-shadow:
      0 0 3px rgba(255, 180, 120, 0.2),
      0 0 8px rgba(210, 106, 53, 0.25);
  }
  50% {
    text-shadow:
      0 0 8px rgba(255, 180, 120, 0.45),
      0 0 18px rgba(210, 106, 53, 0.5);
  }
  100% {
    text-shadow:
      0 0 3px rgba(255, 180, 120, 0.2),
      0 0 8px rgba(210, 106, 53, 0.25);
  }
}

/* ===== Optional faint page breathing ===== */
tw-story {
  animation: caveBreath 10s ease-in-out infinite;
}

@keyframes caveBreath {
  0% {
    box-shadow:
      0 0 30px rgba(0, 0, 0, 0.55),
      0 0 10px rgba(120, 40, 20, 0.10);
  }
  50% {
    box-shadow:
      0 0 38px rgba(0, 0, 0, 0.62),
      0 0 16px rgba(120, 40, 20, 0.16);
  }
  100% {
    box-shadow:
      0 0 30px rgba(0, 0, 0, 0.55),
      0 0 10px rgba(120, 40, 20, 0.10);
  }
}